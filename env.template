# Automation schedule
POST_INTERVAL_HOURS=6
TREND_REGIONS=US
DAILY_IMPACT_RUN_HOUR=8
WEEKLY_MAJOR_EVENTS_RUN_WEEKDAY=0
WEEKLY_MAJOR_EVENTS_RUN_HOUR=9
WEEKLY_MAJOR_EVENTS_PER_LANE=1

# Gemini text generation
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.1-pro
GEMINI_MODEL_CONTENT=gemini-3.1-pro
GEMINI_MODEL_META=gemini-3.1-pro
GEMINI_TEMPERATURE=0.6
GEMINI_MAX_TOKENS=60000
GEMINI_TIMEOUT_SEC=900

# OpenAI weekly discovery
OPENAI_API_KEY=
OPENAI_WEEKLY_MODEL=gpt-5.4-pro

# Google APIs (image generation)
GOOGLE_API_KEY=
YOUTUBE_API_KEY=

# Tavily (web search/extract)
TAVILY_API_KEY=
GEMINI_GROUNDED_DAILY_DISCOVERY=true
SEARCH_WEB_ENABLED=true
SEARCH_WEB_MAX_RESULTS=5
SEARCH_WEB_MAX_PER_QUERY=3
SEARCH_WEB_DEPTH=basic
SEARCH_WEB_INCLUDE_ANSWER=true
SEARCH_WEB_INCLUDE_DOMAINS=
SEARCH_WEB_EXCLUDE_DOMAINS=
YOUTUBE_SEARCH_ENABLED=true
YOUTUBE_MAX_RESULTS=4
YOUTUBE_MAX_PER_QUERY=2
GOOGLE_IMAGE_ENABLED=true
GOOGLE_IMAGE_MODEL=gemini-3-pro-image-preview
GOOGLE_IMAGE_ASPECT_RATIO=16:9

# Content generation
CONTENT_LANGUAGE=English
CONTENT_TONE=neutral, informative, US-market-focused
USE_MULTI_AGENT=true
QUALITY_GATE_REVISIONS=0

# Research search (RSS)
SEARCH_RSS_ENABLED=true
SEARCH_RSS_MAX_RESULTS=4
SEARCH_RSS_MAX_PER_QUERY=3
MAX_EVIDENCE_SOURCES=4

# Blog output
ASTRO_ROOT=../ai_blog_v1_astro
BLOG_DOMAIN=blog.ship-write.com
POST_DRAFT=false

# Fallback metadata (used only if LLM output is missing)
FALLBACK_CATEGORY=trend
FALLBACK_TAGS=topic

# Scraping controls
SCRAPE_DELAY_SEC=1.0
SCRAPE_MAX_RETRIES=2
SCRAPE_BACKOFF_SEC=5.0

FINAL_REVIEW_ENABLED=true
FINAL_REVIEW_REVISIONS=2
MDX_RENDER_GUARD_ENABLED=true
MDX_RENDER_GUARD_REVISIONS=1
MDX_RENDER_AUTO_FIX=true

CONTENT_TIMEZONE=America/New_York
