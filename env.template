# Scraping controls
SCRAPE_DELAY_SEC=5.0
SCRAPE_MAX_RETRIES=2
SCRAPE_BACKOFF_SEC=10.0

# Automation schedule
POST_INTERVAL_HOURS=6
MAX_TOPIC_RANK=3

# Trend collection
TREND_REGIONS=US
TREND_SOURCE=rss
TREND_WINDOW_HOURS=4
TREND_METHOD=trending_searches
TREND_LIMIT=20
TREND_SLEEP_SEC=10.0
CSV_SORT_BY=traffic

# High-intent pipeline (US 24h trends)
HIGH_INTENT_REGIONS=US
HIGH_INTENT_TREND_SOURCE=rss
HIGH_INTENT_TREND_WINDOW_HOURS=24
HIGH_INTENT_TREND_METHOD=trending_searches
HIGH_INTENT_TREND_LIMIT=20
HIGH_INTENT_TREND_SLEEP_SEC=1.0
HIGH_INTENT_CSV_SORT_BY=traffic
HIGH_INTENT_MAX_TOPIC_RANK=5
# Categories are normalized to Google Trends high-level groups:
# B2B/SaaS + Finance/Insurance -> business, Career/Education -> jobs, Tech -> technology
HIGH_INTENT_TREND_CATEGORIES=b2b_saas,finance_insurance,career_education,tech
HIGH_INTENT_ALLOW_RSS_FALLBACK=true
HIGH_INTENT_RSS_MIN_MATCHES=1

# CSV controls
HIGH_INTENT_CSV_ACTIVE_ONLY=false
HIGH_INTENT_CSV_DOWNLOAD_DIR=
HIGH_INTENT_CSV_MAX_RETRIES=2
HIGH_INTENT_CSV_RETRY_DELAY_SEC=2.0
# RSS fallback + filter
HIGH_INTENT_ALLOW_RSS_FALLBACK=true
HIGH_INTENT_RSS_MIN_MATCHES=1

# RSS options
RSS_INCLUDE_IMAGES=true
RSS_INCLUDE_ARTICLES=true
RSS_MAX_ARTICLES_PER_TREND=10
RSS_CACHE=true

# Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3-pro-preview
GEMINI_MODEL_CONTENT=gemini-3-pro-preview
GEMINI_MODEL_META=gemini-3-pro-preview
GEMINI_TEMPERATURE=0.6
GEMINI_MAX_TOKENS=60000
GEMINI_TIMEOUT_SEC=900

# Google APIs (optional)
GOOGLE_API_KEY=
YOUTUBE_API_KEY=

# Tavily (web search/extract)
TAVILY_API_KEY=
SEARCH_WEB_ENABLED=true
SEARCH_WEB_MAX_RESULTS=5
SEARCH_WEB_MAX_PER_QUERY=3
SEARCH_WEB_DEPTH=basic
SEARCH_WEB_INCLUDE_ANSWER=true
SEARCH_WEB_INCLUDE_DOMAINS=
SEARCH_WEB_EXCLUDE_DOMAINS=
YOUTUBE_SEARCH_ENABLED=true
YOUTUBE_MAX_RESULTS=4
YOUTUBE_MAX_PER_QUERY=2
GOOGLE_IMAGE_ENABLED=true
GOOGLE_IMAGE_MODEL=gemini-3-pro-image-preview
GOOGLE_IMAGE_ASPECT_RATIO=16:9

# Content generation
CONTENT_LANGUAGE=English
CONTENT_TONE=neutral, informative
USE_MULTI_AGENT=true
QUALITY_GATE_REVISIONS=0

# Research search (RSS)
SEARCH_RSS_ENABLED=true
SEARCH_RSS_MAX_RESULTS=4
SEARCH_RSS_MAX_PER_QUERY=3
MAX_EVIDENCE_SOURCES=4

# Blog output
ASTRO_ROOT=../ai_blog_v1_astro
BLOG_DOMAIN=blog.ship-write.com
POST_DRAFT=false

# Fallback metadata (used only if LLM output is missing)
FALLBACK_CATEGORY=trend
FALLBACK_TAGS=topic

# Scraping controls
SCRAPE_DELAY_SEC=1.0
SCRAPE_MAX_RETRIES=2
SCRAPE_BACKOFF_SEC=5.0

FINAL_REVIEW_ENABLED=true
FINAL_REVIEW_REVISIONS=2
